# Copy to .env and fill in. `docker compose` reads this automatically.

# Public domain Caddy will serve + get a TLS cert for. Point its DNS A/AAAA
# record at this host first. Also the value to bake into the extension as
# BACKEND_URL (https://<DOMAIN>).
DOMAIN=chat.example.com

# OpenRouter API key — OpenWebUI uses it as the OpenAI-compatible upstream.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# OpenWebUI service-account API key the adapter uses to call OpenWebUI.
# Create it in OpenWebUI: Settings → Account → API Keys (after first-run setup).
OPENWEBUI_API_KEY=sk-owui-...

# Shared secret the extension sends as `Authorization: Bearer`. Build the
# extension with the SAME value: BACKEND_API_KEY=... npm run build.
# Deterrent only (extractable from the bundle) — IP rate limiting is the real
# protection. Generate: `openssl rand -hex 24`.
BACKEND_API_KEY=replace-with-random-hex

# Per-IP rate limit for chat + file upload (requests per minute).
RATE_LIMIT_RPM=60
